{
  "name": "pulsetrack",
  "version": "0.1.0",
  "private": true,
  "description": "Unified Instagram + TikTok analytics platform.",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.1.1",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm -F web dev",
    "dev:api": "pnpm -F api start:dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "format": "pnpm -r format"
  }
}
