# NestJS backend — server-side only (committable template)
# Copy to .env and fill in real values. Never commit the real .env file.

# Supabase
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_ANON_KEY=

# Apify
APIFY_API_TOKEN=

# pg_cron → /webhooks/cron/rescrape-due shared secret
CRON_SECRET=

# Server
PORT=3001
FRONTEND_URL=http://localhost:5173
NODE_ENV=development
